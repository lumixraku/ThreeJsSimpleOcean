{
  "name": "threejs-simple-ocean",
  "version": "0.2.7",
  "description": "Three.js ocean surface shader (depth-aware foam, scrolling normals) with a small render-pipeline helper.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "build": "npm run build:demo",
    "build:demo": "tsc -p tsconfig.build.json --noEmit && vite build",
    "build:lib": "vite build -c vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "preview": "vite preview",
    "prepack": "npm run build:lib"
  },
  "keywords": ["three", "threejs", "webgl", "ocean", "water", "shader", "gamedev"],
  "author": "sam-thewise",
  "license": "MIT",
  "peerDependencies": {
    "three": ">=0.164.0 <0.200.0"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/three": "^0.164.0",
    "three": "^0.164.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
